<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.5.xsd"
        logicalFilePath="db/v.1.0.0/002-create-table-dishes.xml">
    <changeSet id="002-create-table-dishes" author="gigaden">
        <createTable tableName="dishes" schemaName="entities">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="calories" type="numeric">
                <constraints nullable="false"/>
            </column>
            <column name="proteins" type="numeric">
                <constraints nullable="false"/>
            </column>
            <column name="fats" type="numeric">
                <constraints nullable="false"/>
            </column>
            <column name="carbohydrates" type="numeric">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>